PORT=3000

# Ambient Weather API keys — get both at https://ambientweather.net/account
# applicationKey (developer key) + apiKey (user device key)
AMBIENT_APP_KEY=
AMBIENT_API_KEY=

# AirNow API key — register at https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=

# ADS-B receiver URL (FR24 feeder port 8754, or dump1090/readsb JSON endpoint)
ADSB_URL=http://localhost:8754

# APRS-IS server (receive-only)
APRS_HOST=rotate.aprs2.net
APRS_PORT=14580
APRS_FILTER=r/30.2672/-97.7431/80

# Weather station coords (Austin, TX default)
STATION_LAT=30.2672
STATION_LON=-97.7431

# NWS office and gridpoint for forecast (Austin area)
NWS_OFFICE=EWX
NWS_GRID_X=157
NWS_GRID_Y=95
